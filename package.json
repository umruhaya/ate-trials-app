{
  "name": "trials-app",
  "private": true,
  "type": "module",
  "imports": {
    "~/*": "./src/*"
  },
  "lint-staged": {
    "**/*": [
      "biome check --fix --no-errors-on-unmatched"
    ]
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "preview": "bun --bun vite preview",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:pull": "bun --bun drizzle-kit pull",
    "db:studio": "bun --bun drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:reset": "tsx src/db/seed.ts --reset"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@orpc/client": "^1.13.6",
    "@orpc/json-schema": "^1.13.6",
    "@orpc/openapi": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "@orpc/tanstack-query": "^1.13.6",
    "@orpc/zod": "^1.13.6",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-form-start": "^1.29.1",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@latest",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}